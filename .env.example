# ============================================================
#  PlexHarmony - Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Plex ─────────────────────────────────────────────────────
# Your Plex server's local address
PLEX_URL=http://192.168.1.100:32400

# Your Plex token — find it at:
# https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_plex_token_here

# Name of your music library section in Plex (case-sensitive)
PLEX_MUSIC_LIBRARY=Music

# ── Admin Auth ───────────────────────────────────────────────
ADMIN_USERNAME=admin

# Generate with: python backend/generate_password_hash.py
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_GENERATED_HASH

# Random secret key for JWT signing — generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── Discovery (Last.fm) ──────────────────────────────────────
# Free API key at: https://www.last.fm/api/account/create
# Required for similar artist/track discovery features
LASTFM_API_KEY=

# ── Security ─────────────────────────────────────────────────
# Your TrueNAS host IP or hostname (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.50

# URL you access the app from (comma-separated)
ALLOWED_ORIGINS=http://192.168.1.50:8000

# Set to true if you have a reverse proxy with SSL (recommended)
FORCE_HTTPS=false

# Session settings
JWT_EXPIRE_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Tagging Tools (all optional) ─────────────────────────────────────────────

# Beets web plugin URL — enable 'web' plugin in your beets config
# Set host: 0.0.0.0 in beets config to allow LAN access
BEETS_URL=http://192.168.1.x:8337

# Self-hosted MusicBrainz Server (leave blank to use public API)
# https://github.com/metabrainz/musicbrainz-docker
MUSICBRAINZ_URL=

# MusicBrainz Picard server plugin URL
# Requires the picard-web or similar plugin running in Picard
PICARD_URL=http://192.168.1.x:8000

# ── Data persistence ──────────────────────────────────────────────────────────
# Mount this path as a Docker volume to persist settings/themes between restarts
DATA_DIR=/app/data

# ── AI Providers (all optional, configure via Settings UI instead) ────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://192.168.1.x:11434

# ── Download clients (all optional, configure via Settings UI instead) ────────
LIDARR_URL=http://192.168.1.x:8686
LIDARR_API_KEY=
LIDARR_ROOT_FOLDER=/music

QBIT_URL=http://192.168.1.x:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=

DELUGE_URL=http://192.168.1.x:8112
DELUGE_PASSWORD=

SABNZBD_URL=http://192.168.1.x:8080
SABNZBD_API_KEY=
